# Server
NODE_ENV=development
PORT=3000

# Database (Render PostgreSQL connection string)
DATABASE_URL=postgresql://user:password@host:5432/worldcup

# JWT (generate with: openssl rand -base64 32)
JWT_SECRET=replace_with_at_least_32_char_random_secret

# External Football API
API_FOOTBALL_KEY=your_api_football_key_here
API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io

# Admin
ADMIN_EMAIL=admin@example.com

# CORS (comma-separated list of allowed origins)
ALLOWED_ORIGINS=http://localhost:5173,https://your-frontend.vercel.app

# Logging
LOG_LEVEL=info

# WhatsApp prediction-close notifier (optional)
# Set WHATSAPP_ENABLED=true to activate. On first run, a QR code will appear in logs — scan with your phone.
# WHATSAPP_GROUP_ID: the group's serialized ID, e.g. 1234567890-1234567890@g.us
WHATSAPP_ENABLED=false
WHATSAPP_GROUP_ID=
