{
    "name": "wc-predictions-backend",
    "version": "1.0.0",
    "description": "World Cup 2026 Predictions Backend API",
    "main": "dist/index.js",
    "scripts": {
        "dev": "ts-node-dev --respawn --transpile-only -r dotenv/config src/index.ts",
        "build": "tsc",
        "start": "node dist/index.js",
        "migrate": "ts-node -r dotenv/config node_modules/.bin/knex --knexfile knexfile.ts migrate:latest",
        "migrate:prod": "NODE_ENV=production ts-node -r dotenv/config node_modules/.bin/knex --knexfile knexfile.ts migrate:latest",
        "migrate:rollback": "ts-node -r dotenv/config node_modules/.bin/knex --knexfile knexfile.ts migrate:rollback",
        "seed:admin": "ts-node -r dotenv/config scripts/seed-admin.ts"
    },
    "dependencies": {
        "axios": "^1.6.2",
        "bcryptjs": "^2.4.3",
        "cors": "^2.8.5",
        "csv-parse": "^5.5.3",
        "dotenv": "^16.3.1",
        "express": "^4.18.2",
        "express-rate-limit": "^7.1.5",
        "helmet": "^7.1.0",
        "jsonwebtoken": "^9.0.2",
        "knex": "^3.1.0",
        "luxon": "^3.4.4",
        "morgan": "^1.10.0",
        "multer": "^1.4.5-lts.1",
        "pg": "^8.11.3",
        "sharp": "^0.35.2"
    },
    "devDependencies": {
        "@types/bcryptjs": "^2.4.6",
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/jsonwebtoken": "^9.0.5",
        "@types/luxon": "^3.3.7",
        "@types/morgan": "^1.9.9",
        "@types/multer": "^1.4.13",
        "@types/node": "^20.10.0",
        "@types/pg": "^8.10.9",
        "ts-node": "^10.9.2",
        "ts-node-dev": "^2.0.0",
        "typescript": "^5.3.2"
    }
}
